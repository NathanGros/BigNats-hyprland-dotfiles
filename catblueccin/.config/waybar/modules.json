{
	"custom/separatorleft": {
        "format": " ",
        "tooltip": false
	},
	"custom/separator": {
        "format": " ",
        "tooltip": false
	},
	"custom/separatorright": {
        "format": " ",
        "tooltip": false
	},

    "custom/menu": {
        "format": "пРО",
        "on-click": "~/.config/hypr/scripts/appmenu_toggle.sh",
        "tooltip-format": "Applications"
    },

    "hyprland/workspaces": {
        "show-special": true,
        "special-visible-only": false,
        "on-scroll-up": "hyprctl dispatch workspace r-1",
        "on-scroll-down": "hyprctl dispatch workspace r+1",
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": ""
        },
        "persistent-workspaces": {
            "*": 5
        }
    },

    "tray": {
        "icon-size": 18,
        "spacing": 7
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}\n\nClick to go to\nMiddle click to toggle fullscreen\nRight click to close",
        "on-click": "activate",
        "on-click-middle": "fullscreen",
        "on-click-right": "close",
        "on-scroll-up": "hyprctl dispatch movefocus l",
        "on-scroll-down": "hyprctl dispatch movefocus r",
        "max-length": 15
    },

    "custom/clipboard": {
        "format": "оµї",
        "on-click": "~/.config/hypr/scripts/clipboard_toggle.sh",
        "tooltip-format": "Open clipboard"
    },

    "clock": {
        "format": "{:%H:%M   %d-%m-%Y}",
        "tooltip-format": "{:%A %d %B %Y}\nToggle todo list",
        "on-click": "~/.config/hypr/scripts/todo_toggle.sh",
        "min-length": 17,
        "max-length": 17
    },

    "custom/screenshot": {
        "format": "{}",
        "exec": "~/.config/hypr/scripts/recording_state.sh",
        "interval": 1,
        "on-click": "~/.config/hypr/scripts/screenshotlist.sh",
        "tooltip-format": "Open screenshot menu"
    },

    "memory": {
        "format": "оЊП  {}%",
        "tooltip-format": " {used} / {total}Gib RAM used",
        "interval": 5,
        "on-click": "foot -T btop -e btop",
        "min-length": 7,
        "max-length": 7
    },

    "cpu": {
        "format": "пТЉ   {usage}%",
        "interval": 1,
        "on-click": "foot -T btop -e btop",
        "min-length": 7,
        "max-length": 7,
        "tooltip": false
    },

    "wireplumber": {
        "format": "{icon}",
        "format-muted": "ої® ",
        "tooltip-format": "{volume}%",
        "scroll-step": 5,
        "max-volume": "100",
        "format-icons": [
            "пА¶ ",
            "пАІ ",
            "пАІ ",
            "пА® ",
            "пА® "
        ],
        "min-length": 3,
        "max-length": 3,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },

    "backlight": {
        "format": "{icon}",
        "format-icons": [
            "оПХ",
            "оПУ",
            "оПТ",
            "оПС",
            "оПР",
            "оПО",
            "оПН",
            "оПМ",
            "оПЛ",
            "оПЙ",
            "оП£"
        ],
        "tooltip-format": "{percent}%",
        "min-length": 3,
        "max-length": 3,
        "scroll-step": 10
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}",
        "format-full": "у∞ВД",
        "format-charging": "у∞ВД",
        "format-plugged": "у∞ВД",
        "format-icons": ["у∞ВО", "у∞БЇ", "у∞Бї", "у∞БЉ", "у∞Бљ", "у∞БЊ", "у∞Бњ", "у∞ВА", "у∞ВБ", "у∞ВВ", "у∞Бє"],
        "format-off": "",
        "tooltip-format-full": "Battery full",
        "tooltip-format": "{capacity}% ({time})",
        "on-click": "power-options-gtk",
        "interval": 5,
        "min-length": 3,
        "max-length": 3
    },

    "network": {
        "format": "{icon}",
        "format-wifi": "{icon}",
        "format-ethernet": "ољД",
        "format-disconnected": "у∞§Ђ",
        "format-disabled": "у∞§Ѓ",
        "format-icons": ["у∞§ѓ", "у∞§Я", "у∞§Ґ", "у∞§•", "у∞§®"],
        "tooltip-format": "{ifname} via {gwaddri}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname}",
        "tooltip-format-disconnected": "Searching for network...",
        "tooltip-format-disabled": "Wifi disabled",
        "on-click": "~/.config/hypr/scripts/wifilist_toggle.sh",
        "interval": 5,
        "min-length": 2,
        "max-length": 2
    },

    "custom/updates": {
        "format": "рЬ±≠ {}",
        "escape": true,
        "exec": "~/.config/hypr/scripts/updates_count.sh",
        "interval": 600,
        "on-click": "~/.config/hypr/scripts/updates_toggle.sh",
        "tooltip-format": "Update system"
    },

    "custom/wlogout": {
        "format": "пАС",
        "on-click": "~/.config/hypr/scripts/logout_toggle.sh",
        "tooltip-format": "Logout"
    }
}
